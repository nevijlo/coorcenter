      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --brand-blue: #0066B3;\n    --brand-red: #D62828;\n    --bg-gray: #E2E8F0;\n    --border-black: #000000;\n  }\n\n  .font-mono { font-family: 'IBM Plex Mono', monospace; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .diagonal-pattern {\n    background-image: repeating-linear-gradient(45deg, #e2e8f0 0, #e2e8f0 1px, transparent 0, transparent 50%);\n    background-size: 8px 8px;\n  }\n\n  /* Ticker animation */\n  @keyframes ticker {\n    0% { transform: translateX(100%); }\n    100% { transform: translateX(-100%); }\n  }\n  .ticker-scroll {\n    display: inline-block;\n    white-space: nowrap;\n    animation: ticker 30s linear infinite;\n  }\n\n  .ledger-input {\n    border-bottom: 1px solid var(--border-black);\n    background: transparent;\n    width: 100%;\n    padding: 8px 0;\n    outline: none;\n    font-family: 'Inter', sans-serif;\n  }\n  .ledger-input:focus {\n    border-bottom: 2px solid var(--brand-blue);\n  }\n\n  .hover-row:hover {\n    background-color: var(--brand-blue);\n    color: white;\n  }\n</style>\n\n<div class=\"bg-white text-black font-sans selection:bg-blue-100 min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"w-full bg-[#D62828] h-8 flex items-center overflow-hidden border-b border-black\" data-kid=\"2\">\n    <div class=\"ticker-scroll text-white font-mono text-xs uppercase tracking-widest px-4\" data-kid=\"3\">\n      ВНИМАНИЕ: ЕСЛИ ВАМ ИЗВЕСТНО О ГОТОВЯЩЕМСЯ ПРЕСТУПЛЕНИИ — НЕМЕДЛЕННО ЗВОНИТЕ 112 • СЛУЖБА БЕЗОПАСНОСТИ САФУ • ЭКСТРЕННАЯ ПОМОЩЬ • 112 • 112 • 112 • 112\n    </div>\n  </div>\n\n  \n  <header class=\"border-b border-black py-16 px-8 lg:px-16\" data-kid=\"4\">\n    <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row justify-between items-start gap-12\" data-kid=\"5\">\n      <div class=\"max-w-3xl\" data-kid=\"6\">\n        <div class=\"font-mono text-sm mb-4 text-[var(--brand-blue)] flex items-center gap-2\" data-kid=\"7\">\n          <i class=\"ti ti-terminal text-lg\" data-kid=\"8\"></i>\n          <span data-kid=\"9\">SYSTEM_INIT: COORDINATION_CENTER_NARFU</span>\n        </div>\n        <h1 class=\"font-mono text-4xl lg:text-6xl font-bold leading-tight mb-8 tracking-tighter uppercase\" data-kid=\"10\">\n          Координационный <br data-kid=\"11\">центр САФУ\n        </h1>\n        <p class=\"text-xl max-w-2xl mb-12 text-gray-600 leading-relaxed\" data-kid=\"12\">\n          Безопасное пространство для своевременного сообщения о потенциальных угрозах, конфликтах и деструктивном поведении в образовательной среде.\n        </p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"13\">\n          <button class=\"bg-black text-white font-mono uppercase tracking-widest px-8 py-4 border border-black hover:bg-white hover:text-black transition-colors rounded-none\" data-kid=\"14\">\n            [ СООБЩИТЬ_О_ПРОБЛЕМЕ ]\n          </button>\n          <button class=\"bg-white text-black font-mono uppercase tracking-widest px-8 py-4 border border-black hover:bg-black hover:text-white transition-colors rounded-none\" data-kid=\"15\">\n            [ КОНТАКТЫ ]\n          </button>\n        </div>\n      </div>\n      <div class=\"lg:w-80 flex flex-col gap-6\" data-kid=\"16\">\n        <div class=\"border border-black p-6 relative overflow-hidden\" data-kid=\"17\">\n          <div class=\"absolute top-0 left-0 w-2 h-2 border-t border-l border-black\" data-kid=\"18\"></div>\n          <div class=\"absolute top-0 right-0 w-2 h-2 border-t border-r border-black\" data-kid=\"19\"></div>\n          <div class=\"absolute bottom-0 left-0 w-2 h-2 border-b border-l border-black\" data-kid=\"20\"></div>\n          <div class=\"absolute bottom-0 right-0 w-2 h-2 border-b border-r border-black\" data-kid=\"21\"></div>\n          <img src=\"/api/local/images/center-logo.png\" alt=\"Logo\" class=\"w-full h-auto mb-4 grayscale contrast-125\" loading=\"lazy\" decoding=\"async\" data-kid=\"22\">\n          <div class=\"font-mono text-[10px] text-gray-400 uppercase\" data-kid=\"23\">Verification ID: NARFU-SEC-001</div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"border-b border-black\" data-kid=\"24\">\n    <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row\" data-kid=\"25\">\n      <div class=\"lg:w-1/3 border-r border-black p-8 lg:p-16 bg-[var(--bg-gray)]/30\" data-kid=\"26\">\n        <h2 class=\"font-mono text-3xl font-bold uppercase mb-6 flex items-center gap-3\" data-kid=\"27\">\n          <i class=\"ti ti-hash text-[var(--brand-blue)]\" data-kid=\"28\"></i>\n          Индекс\n        </h2>\n        <p class=\"text-sm text-gray-500 font-mono\" data-kid=\"29\">\n          КЛАССИФИКАЦИЯ ОБРАЩЕНИЙ ПО ТИПАМ И УРОВНЯМ УГРОЗЫ. ВЫБЕРИТЕ СООТВЕТСТВУЮЩИЙ ПУНКТ ДЛЯ НАЧАЛА ПРОТОКОЛА.\n        </p>\n      </div>\n      <div class=\"lg:w-2/3\" data-kid=\"30\">\n        <div class=\"flex flex-col\" data-kid=\"31\">\n          \n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"32\">\n            <div class=\"flex items-center gap-8\" data-kid=\"33\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"34\">01</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"35\">Буллинг / травля</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"36\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"37\">\n            <div class=\"flex items-center gap-8\" data-kid=\"38\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"39\">02</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"40\">Кибербуллинг</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"41\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"42\">\n            <div class=\"flex items-center gap-8\" data-kid=\"43\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"44\">03</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"45\">Подозрительные публикации</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"46\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"47\">\n            <div class=\"flex items-center gap-8\" data-kid=\"48\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"49\">04</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"50\">Терроризм и экстремизм</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"51\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"52\">\n            <div class=\"flex items-center gap-8\" data-kid=\"53\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"54\">05</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"55\">Межнациональные конфликты</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"56\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"57\">\n            <div class=\"flex items-center gap-8\" data-kid=\"58\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"59\">06</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"60\">Деструктивное поведение</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"61\"></i>\n          </div>\n          <div class=\"hover-row border-b border-black p-6 flex items-center justify-between cursor-pointer transition-none group\" data-kid=\"62\">\n            <div class=\"flex items-center gap-8\" data-kid=\"63\">\n              <span class=\"font-mono text-2xl font-bold opacity-30 group-hover:opacity-100\" data-kid=\"64\">07</span>\n              <span class=\"font-mono text-lg uppercase tracking-tight\" data-kid=\"65\">Угрозы в вузе / общежитии</span>\n            </div>\n            <i class=\"ti ti-crosshair text-2xl opacity-0 group-hover:opacity-100\" data-kid=\"66\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"border-b border-black\" data-kid=\"67\">\n    <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row\" data-kid=\"68\">\n      \n      <div class=\"lg:w-3/4 p-8 lg:p-16\" data-kid=\"69\">\n        <div class=\"font-mono text-sm mb-12 flex items-center gap-2\" data-kid=\"70\">\n          <i class=\"ti ti-file-text\" data-kid=\"71\"></i>\n          <span data-kid=\"72\">FORM_ID: REPORT_2024_A</span>\n        </div>\n        \n        <form class=\"space-y-12\" data-kid=\"73\">\n          <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12\" data-kid=\"74\">\n            <div class=\"space-y-2\" data-kid=\"75\">\n              <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"76\">01. КАТЕГОРИЯ_ОБРАЩЕНИЯ</label>\n              <select class=\"ledger-input appearance-none rounded-none cursor-pointer\" data-kid=\"77\">\n                <option data-kid=\"78\">Выберите тип</option>\n                <option data-kid=\"79\">Буллинг</option>\n                <option data-kid=\"80\">Терроризм</option>\n              </select>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"81\">\n              <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"82\">02. ВУЗ / ВЫСШАЯ_ШКОЛА</label>\n              <input type=\"text\" placeholder=\"Укажите подразделение\" class=\"ledger-input\" data-kid=\"83\">\n            </div>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"84\">\n            <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"85\">03. ДЕТАЛЬНОЕ_ОПИСАНИЕ_СИТУАЦИИ</label>\n            <div class=\"relative\" data-kid=\"86\">\n              <textarea rows=\"6\" class=\"ledger-input resize-none bg-transparent relative z-10\" placeholder=\"Изложите факты максимально подробно...\" data-kid=\"87\"></textarea>\n              <div class=\"absolute inset-0 diagonal-pattern -z-0 opacity-20\" data-kid=\"88\"></div>\n            </div>\n          </div>\n\n          <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\" data-kid=\"89\">\n            <div class=\"space-y-2\" data-kid=\"90\">\n              <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"91\">04. МЕСТО</label>\n              <input type=\"text\" class=\"ledger-input\" data-kid=\"92\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"93\">\n              <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"94\">05. КУРС</label>\n              <input type=\"text\" class=\"ledger-input\" data-kid=\"95\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"96\">\n              <label class=\"font-mono text-xs uppercase text-gray-400\" data-kid=\"97\">06. КОНТАКТЫ</label>\n              <input type=\"text\" class=\"ledger-input\" placeholder=\"Необязательно\" data-kid=\"98\">\n            </div>\n          </div>\n\n          <div class=\"pt-8\" data-kid=\"99\">\n            <button class=\"w-full bg-[var(--brand-blue)] text-white font-mono uppercase tracking-[0.2em] py-6 hover:bg-black transition-colors rounded-none\" data-kid=\"100\">\n              ОТПРАВИТЬ ОТЧЕТ / SEND_REPORT\n            </button>\n          </div>\n        </form>\n      </div>\n\n      \n      <aside class=\"lg:w-1/4 border-l border-black p-8 bg-[var(--bg-gray)]/20\" data-kid=\"101\">\n        <h3 class=\"font-mono text-sm font-bold uppercase mb-8 border-b border-black pb-2 flex items-center gap-2\" data-kid=\"102\">\n          <i class=\"ti ti-target\" data-kid=\"103\"></i>\n          Правовое поле\n        </h3>\n        <div class=\"space-y-12\" data-kid=\"104\">\n          <div class=\"space-y-2\" data-kid=\"105\">\n            <div class=\"font-mono text-xs font-bold text-[var(--brand-blue)]\" data-kid=\"106\">СТ. 205 УК РФ</div>\n            <p class=\"text-[11px] leading-relaxed text-gray-500 uppercase\" data-kid=\"107\">\n              Терроризм: совершение взрыва, поджога или иных действий, устрашающих население. Уголовная ответственность.\n            </p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"108\">\n            <div class=\"font-mono text-xs font-bold text-[var(--brand-blue)]\" data-kid=\"109\">СТ. 282 УК РФ</div>\n            <p class=\"text-[11px] leading-relaxed text-gray-500 uppercase\" data-kid=\"110\">\n              Экстремизм: возбуждение ненависти либо вражды, а равно унижение человеческого достоинства.\n            </p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"111\">\n            <div class=\"font-mono text-xs font-bold text-[var(--brand-blue)]\" data-kid=\"112\">СТ. 207 УК РФ</div>\n            <p class=\"text-[11px] leading-relaxed text-gray-500 uppercase\" data-kid=\"113\">\n              Ложные сообщения: заведомо ложное сообщение об акте терроризма влечет за собой строгую ответственность.\n            </p>\n          </div>\n          <div class=\"diagonal-pattern h-24 w-full opacity-30 mt-8\" data-kid=\"114\"></div>\n        </div>\n      </aside>\n    </div>\n  </section>\n\n  \n  <section class=\"border-b border-black\" data-kid=\"115\">\n    <div class=\"max-w-7xl mx-auto p-8 lg:p-16\" data-kid=\"116\">\n      <h2 class=\"font-mono text-3xl font-bold uppercase mb-12\" data-kid=\"117\">Реестр персонала</h2>\n      <div class=\"overflow-x-auto\" data-kid=\"118\">\n        <table class=\"w-full border-collapse font-mono text-sm\" data-kid=\"119\">\n          <thead data-kid=\"120\">\n            <tr class=\"border-b-2 border-black text-left\" data-kid=\"121\">\n              <th class=\"py-4 pr-4 uppercase tracking-widest text-gray-400 font-normal\" data-kid=\"122\">Должность</th>\n              <th class=\"py-4 pr-4 uppercase tracking-widest text-gray-400 font-normal\" data-kid=\"123\">ФИО</th>\n              <th class=\"py-4 uppercase tracking-widest text-gray-400 font-normal\" data-kid=\"124\">Контактный Email</th>\n            </tr>\n          </thead>\n          <tbody data-kid=\"125\">\n            <tr class=\"border-b border-gray-200\" data-kid=\"126\">\n              <td class=\"py-4 pr-4\" data-kid=\"127\">Директор</td>\n              <td class=\"py-4 pr-4 font-bold\" data-kid=\"128\">Ратушинский В. С.</td>\n              <td class=\"py-4 text-[var(--brand-blue)]\" data-kid=\"129\">v.ratushinskij@narfu.ru</td>\n            </tr>\n            <tr class=\"border-b border-gray-200 bg-gray-50\" data-kid=\"130\">\n              <td class=\"py-4 pr-4\" data-kid=\"131\">Директор УМЦ</td>\n              <td class=\"py-4 pr-4 font-bold\" dat