      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Open+Sans:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --safu-blue: #0066B3;\n    --safu-red: #D62828;\n    --safu-gray: #F5F5F5;\n    --surface: #FAFAFA;\n    --text-main: #2D3748;\n  }\n\n  body {\n    font-family: 'Open Sans', sans-serif;\n    color: var(--text-main);\n    background-color: var(--safu-gray);\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Custom scroll behavior */\n  html {\n    scroll-behavior: smooth;\n  }\n\n  /* Glassmorphism for the hero overlay */\n  .hero-overlay {\n    background: linear-gradient(135deg, rgba(0, 102, 179, 0.9) 0%, rgba(0, 42, 80, 0.85) 100%);\n  }\n\n  /* Card Hover Effect */\n  .category-card:hover {\n    transform: scale(1.02);\n    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n  }\n\n  /* Accordion styles */\n  .accordion-content {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease-out;\n  }\n  .accordion-item:focus-within .accordion-content {\n    max-height: 200px;\n  }\n  .accordion-item:focus-within i.ti-chevron-down {\n    transform: rotate(180deg);\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-4\" data-kid=\"4\">\n        <img src=\"/logo.png\" alt=\"САФУ\" class=\"h-10 w-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n        <div class=\"h-8 w-px bg-gray-300 hidden sm:block\" data-kid=\"6\"></div>\n        <span class=\"font-heading text-xs uppercase tracking-widest text-[var(--safu-blue)] leading-tight hidden sm:block\" data-kid=\"7\">\n          Координационный<br data-kid=\"8\">Центр\n        </span>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"9\">\n        <a href=\"#report\" class=\"bg-[var(--safu-blue)] text-white px-6 py-2.5 rounded-full font-semibold hover:bg-blue-700 transition-colors shadow-sm\" data-kid=\"10\">\n          Сообщить\n        </a>\n      </div>\n    </div>\n  </nav>\n\n  \n  <header class=\"pt-8 pb-20 px-6\" data-kid=\"11\">\n    <div class=\"max-w-7xl mx-auto relative\" data-kid=\"12\">\n      \n      <div class=\"relative overflow-hidden rounded-[60px] min-h-[500px] flex items-center shadow-2xl\" data-kid=\"13\">\n        <img src=\"https://images.unsplash.com/photo-1605364850032-e25ae0835552?auto=format&w=1280&q=80&fit=crop\" alt=\"University Hallway\" class=\"absolute inset-0 w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"14\">\n        <div class=\"absolute inset-0 hero-overlay\" data-kid=\"15\"></div>\n        \n        <div class=\"relative z-10 w-full px-12 lg:px-24 py-16 text-white max-w-4xl\" data-kid=\"16\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"17\">\n            <div class=\"bg-white/20 p-4 rounded-2xl backdrop-blur-sm\" data-kid=\"18\">\n              <i class=\"ti ti-shield-check text-4xl\" data-kid=\"19\"></i>\n            </div>\n            <span class=\"font-heading text-lg tracking-wide opacity-90\" data-kid=\"20\">Безопасность и поддержка</span>\n          </div>\n          <h1 class=\"font-heading text-4xl md:text-6xl font-extrabold leading-[1.1] mb-8\" data-kid=\"21\">\n            Защищаем ваше пространство вместе\n          </h1>\n          <p class=\"text-xl md:text-2xl opacity-90 font-light leading-relaxed max-w-2xl\" data-kid=\"22\">\n            Координационный центр САФУ — это надежный щит против угроз и место, где вас всегда выслушают.\n          </p>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute -bottom-10 left-1/2 -translate-x-1/2 w-full max-w-3xl px-6\" data-kid=\"23\">\n        <div class=\"bg-[var(--safu-red)] text-white p-6 rounded-[30px] shadow-xl flex items-center gap-6 border-4 border-white\" data-kid=\"24\">\n          <div class=\"bg-white/20 w-12 h-12 rounded-full flex items-center justify-center shrink-0\" data-kid=\"25\">\n            <i class=\"ti ti-alert-triangle text-2xl\" data-kid=\"26\"></i>\n          </div>\n          <div class=\"flex-1\" data-kid=\"27\">\n            <h3 class=\"font-heading text-lg font-bold\" data-kid=\"28\">Экстренная ситуация?</h3>\n            <p class=\"text-sm opacity-90\" data-kid=\"29\">При угрозе жизни или готовящемся преступлении — немедленно звоните <span class=\"font-bold underline text-xl\" data-kid=\"30\">112</span></p>\n          </div>\n          <a href=\"tel:112\" class=\"bg-white text-[var(--safu-red)] px-8 py-3 rounded-full font-bold hover:bg-gray-100 transition-colors hidden md:block\" data-kid=\"31\">\n            Позвонить\n          </a>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"py-32 px-6 bg-white\" data-kid=\"32\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"33\">\n      <div class=\"text-center mb-16\" data-kid=\"34\">\n        <span class=\"text-[var(--safu-blue)] font-bold tracking-widest uppercase text-sm mb-4 block\" data-kid=\"35\">Шаг 1</span>\n        <h2 class=\"font-heading text-4xl font-bold mb-4\" data-kid=\"36\">С чем вы столкнулись?</h2>\n        <p class=\"text-gray-500 max-w-xl mx-auto text-lg\" data-kid=\"37\">Выберите категорию, чтобы мы могли оказать квалифицированную помощь.</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"38\">\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"39\">\n          <div class=\"bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"40\">\n            <i class=\"ti ti-users text-3xl text-[var(--safu-blue)] group-hover:text-white\" data-kid=\"41\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"42\">Буллинг и травля</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"43\">Помощь в разрешении конфликтов в коллективе.</p>\n        </div>\n\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"44\">\n          <div class=\"bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"45\">\n            <i class=\"ti ti-device-laptop text-3xl text-[var(--safu-blue)] group-hover:text-white\" data-kid=\"46\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"47\">Кибербуллинг</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"48\">Защита от агрессии и угроз в цифровом пространстве.</p>\n        </div>\n\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"49\">\n          <div class=\"bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"50\">\n            <i class=\"ti ti-search text-3xl text-[var(--safu-blue)] group-hover:text-white\" data-kid=\"51\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"52\">Подозрительные публикации</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"53\">Если вы заметили деструктивный контент в соцсетях.</p>\n        </div>\n\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"54\">\n          <div class=\"bg-red-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-red)] transition-colors\" data-kid=\"55\">\n            <i class=\"ti ti-shield-off text-3xl text-[var(--safu-red)] group-hover:text-white\" data-kid=\"56\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"57\">Терроризм и экстремизм</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"58\">Предотвращение идеологических угроз и вербовки.</p>\n        </div>\n\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"59\">\n          <div class=\"bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"60\">\n            <i class=\"ti ti-world text-3xl text-[var(--safu-blue)] group-hover:text-white\" data-kid=\"61\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"62\">Межнациональные конфликты</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"63\">Профилактика вражды на почве веры или нации.</p>\n        </div>\n\n        \n        <div class=\"category-card p-10 bg-[var(--safu-gray)] rounded-[24px] transition-all duration-300 cursor-pointer group\" data-kid=\"64\">\n          <div class=\"bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"65\">\n            <i class=\"ti ti-bolt text-3xl text-[var(--safu-blue)] group-hover:text-white\" data-kid=\"66\"></i>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold mb-2\" data-kid=\"67\">Агрессивное поведение</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"68\">Сообщите о случаях неадекватного или опасного поведения.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"report\" class=\"py-24 px-6 bg-[var(--safu-gray)]\" data-kid=\"69\">\n    <div class=\"max-w-4xl mx-auto\" data-kid=\"70\">\n      <div class=\"bg-white p-12 rounded-[40px] shadow-xl\" data-kid=\"71\">\n        <div class=\"flex items-center gap-6 mb-12 pb-8 border-b border-gray-100\" data-kid=\"72\">\n          <div class=\"w-16 h-16 bg-[var(--safu-blue)] rounded-full flex items-center justify-center text-white shrink-0\" data-kid=\"73\">\n            <i class=\"ti ti-file-description text-3xl\" data-kid=\"74\"></i>\n          </div>\n          <div data-kid=\"75\">\n            <h2 class=\"font-heading text-3xl font-bold\" data-kid=\"76\">Опишите ситуацию</h2>\n            <p class=\"text-gray-500\" data-kid=\"77\">Ваше обращение поможет сделать университет безопаснее.</p>\n          </div>\n        </div>\n\n        <form class=\"space-y-8\" data-kid=\"78\">\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"79\">\n            <div class=\"space-y-2\" data-kid=\"80\">\n              <label class=\"text-sm font-bold uppercase tracking-wider text-gray-400 px-4\" data-kid=\"81\">Вуз / Высшая школа</label>\n              <div class=\"relative\" data-kid=\"82\">\n                <select class=\"w-full bg-gray-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-blue-500 appearance-none\" data-kid=\"83\">\n                  <option data-kid=\"84\">Выберите вуз</option>\n                  <option data-kid=\"85\">САФУ (г. Архангельск)</option>\n                  <option data-kid=\"86\">ВШИТиАС</option>\n                </select>\n                <i class=\"ti ti-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"87\"></i>\n              </div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"88\">\n              <label class=\"text-sm font-bold uppercase tracking-wider text-gray-400 px-4\" data-kid=\"89\">Курс обучения</label>\n              <div class=\"relative\" data-kid=\"90\">\n                <select class=\"w-full bg-gray-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-blue-500 appearance-none\" data-kid=\"91\">\n                  <option data-kid=\"92\">Выберите курс</option>\n                  <option data-kid=\"93\">1 курс</option>\n                  <option data-kid=\"94\">2 курс</option>\n                  <option data-kid=\"95\">Магистратура</option>\n                </select>\n                <i class=\"ti ti-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"96\"></i>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"97\">\n            <label class=\"text-sm font-bold uppercase tracking-wider text-gray-400 px-4\" data-kid=\"98\">Где это произошло?</label>\n            <input type=\"text\" placeholder=\"Например: общежитие №1 или конкретная аудитория\" class=\"w-full bg-gray-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-blue-500\" data-kid=\"99\">\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"100\">\n            <label class=\"text-sm font-bold uppercase tracking-wider text-gray-400 px-4\" data-kid=\"101\">Подробности происшествия</label>\n            <textarea rows=\"6\" placeholder=\"Опишите ситуацию максимально детально...\" class=\"w-full bg-gray-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-blue-500 resize-none\" data-kid=\"102\"></textarea>\n          </div>\n\n          <div class=\"flex items-center justify-between gap-6 pt-4\" data-kid=\"103\">\n            <div class=\"flex items-center gap-4 text-sm text-gray-500\" data-kid=\"104\">\n              <i class=\"ti ti-info-circle text-xl text-[var(--safu-blue)]\" data-kid=\"105\"></i>\n              Ваши данные защищены и передаются только профильным специалистам.\n            </div>\n            <button class=\"bg-[var(--safu-blue)] text-white px-12 py-5 rounded-[20px] font-heading text-lg font-bold hover:bg-blue-700 transition-all shadow-lg hover:shadow-blue-200\" data-kid=\"106\">\n              Отправить заявку\n            </button>\n          </div>\n        </form>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6\" data-kid=\"107\">\n    <div class=\"max-w-7xl mx-auto text-center\" data-kid=\"108\">\n      <h2 class=\"font-heading text-4xl font-bold mb-16\" data-kid=\"109\">Наши специалисты</h2>\n      \n      <div class=\"flex flex-wrap justify-center gap-12\" data-kid=\"110\">\n        \n        <div class=\"group relative\" data-kid=\"111\">\n          <div class=\"w-32 h-32 rounded-full bg-blue-50 flex items-center justify-center border-4 border-white shadow-lg group-hover:scale-110 transition-transform cursor-help\" data-kid=\"112\">\n            <span class=\"font-heading text-4xl text-[var(--safu-blue)]\" data-kid=\"113\">РВ</span>\n          </div>\n          <div class=\"absolute top-full mt-4 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap bg-white p-4 rounded-2xl shadow-xl z-20 pointer-events-none\" data-kid=\"114\">\n            <h4 class=\"font-bold text-[var(--safu-blue)]\" data-kid=\"115\">Ратушинский Владислав</h4>\n            <p class=\"text-xs text-gray-500\" data-kid=\"116\">Директор центра</p>\n          </div>\n        </div>\n\n        \n        <div class=\"group relative\" data-kid=\"117\">\n          <div class=\"w-32 h-32 rounded-full bg-blue-50 flex items-center justify-center border-4 border-white shadow-lg group-hover:scale-110 transition-transform cursor-help\" data-kid=\"118\">\n            <span class=\"font-heading text-4xl text-[var(--safu-blue)]\" data-kid=\"119\">СН</span>\n          </div>\n          <div class=\"absolute top-full mt-4 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap bg-white p-4 rounded-2xl shadow-xl z-20 pointer-events-none\" data-kid=\"120\">\n            <h4 class=\"font-bold text-[var(--safu-blue)]\" data-kid=\"121\">Савельева Надежда</h4>\n            <p class=\"text-xs text-gray-500\" data-kid=\"122\">Директор УМЦ</p>\n          </div>\n        </div>\n\n        \n        <div class=\"group relative\" data-kid=\"123\">\n          <div class=\"w-32 h-32 rounded-full bg-blue-50 flex items-center justify-center border-4 border-white shadow-lg group-hover:scale-110 transition-transform cursor-help\" data-kid=\"124\">\n            <span class=\"font-heading text-4xl text-[var(--safu-blue)]\" data-kid=\"125\">ЛЛ</span>\n          </div>\n          <div class=\"absolute top-full mt-4 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap bg-white p-4 rounded-2xl shadow-xl z-20 pointer-events-none\" data-kid=\"126\">\n            <h4 class=\"font-bold text-[var(--safu-blue)]\" data-kid=\"127\">Лещук Лаурита</h4>\n            <p class=\"text-xs text-gray-500\" data-kid=\"128\">Менеджер проектов</p>\n          </div>\n        </div>\n\n        \n        <div class=\"group relative\" data-kid=\"129\">\n          <div class=\"w-32 h-32 rounded-full bg-blue-50 flex items-center justify-center border-4 border-white shadow-lg group-hover:scale-110 transition-transform cursor-help\" data-kid=\"130\">\n            <span class=\"font-heading text-4xl text-[var(--safu-blue)]\" data-kid=\"131\">КЮ</span>\n          </div>\n          <div class=\"absolute top-full mt-4 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap bg-white p-4 rounded-2xl shadow-xl z-20 pointer-events-none\" data-kid=\"132\">\n            <h4 class=\"font-bold text-[var(--safu-blue)]\" data-kid=\"133\">Кузнецова Юлия</h4>\n            <p class=\"text-xs text-gray-500\" data-kid=\"134\">Менеджер проектов</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 px-6 bg-white\" data-kid=\"135\">\n    <div class=\"max-w-4xl mx-auto\" data-kid=\"136\">\n      <h2 class=\"font-heading text-3xl font-bold mb-12 text-center\" data-kid=\"137\">Законодательство РФ</h2>\n      \n      <div class=\"space-y-4\" data-kid=\"138\">\n        \n        <div class=\"accordion-item\" tabindex=\"0\" data-kid=\"139\">\n          <div class=\"bg-[var(--safu-gray)] p-8 rounded-[24px] cursor-pointer flex items-center justify-between group\" data-kid=\"140\">\n            <div class=\"flex items-center gap-6\" data-kid=\"141\">\n              <i class=\"ti ti-scale text-2xl text-[var(--safu-blue)]\" data-kid=\"142\"></i>\n              <h3 class=\"font-heading text-xl font-bold\" data-kid=\"143\">Терроризм</h3>\n            </div>\n            <i class=\"ti ti-chevron-down text-xl text-gray-400 group-hover:text-[var(--safu-blue)] transition-all\" data-kid=\"144\"></i>\n          </div>\n          <div class=\"accordion-content bg-white px-8\" data-kid=\"145\">\n            <p class=\"py-6 text-gray-600 leading-relaxed\" data-kid=\"146\">\n              Уголовная ответственность за совершение террористического акта предусмотрена ст. 205 УК РФ. Наказание может достигать пожизненного лишения свободы. Также ответственность несут лица, оказывающие содействие или оправдывающие терроризм.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"accordion-item\" tabindex=\"0\" data-kid=\"147\">\n          <div class=\"bg-[var(--safu-gray)] p-8 rounded-[24px] cursor-pointer flex items-center justify-between group\" data-kid=\"148\">\n            <div class=\"flex items-center gap-6\" data-kid=\"149\">\n              <i class=\"ti ti-gavel text-2xl text-[var(--safu-blue)]\" data-kid=\"150\"></i>\n              <h3 class=\"font-heading text-xl font-bold\" data-kid=\"151\">Экстремистская деятельность</h3>\n            </div>\n            <i class=\"ti ti-chevron-down text-xl text-gray-400 group-hover:text-[var(--safu-blue)] transition-all\" data-kid=\"152\"></i>\n          </div>\n          <div class=\"accordion-content bg-white px-8\" data-kid=\"153\">\n            <p class=\"py-6 text-gray-600 leading-relaxed\" data-kid=\"154\">\n              Ответственность по ст. 282-282.3 УК РФ. Включает возбуждение ненависти либо вражды, а равно унижение человеческого достоинства по признакам пола, расы, национальности, языка или религии.\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"accordion-item\" tabindex=\"0\" data-kid=\"155\">\n          <div class=\"bg-[var(--safu-gray)] p-8 rounded-[24px] cursor-pointer flex items-center justify-between group\" data-kid=\"156\">\n            <div class=\"flex items-center gap-6\" data-kid=\"157\">\n              <i class=\"ti ti-message-report text-2xl text-[var(--safu-red)]\" data-kid=\"158\"></i>\n              <h3 class=\"font-heading text-xl font-bold\" data-kid=\"159\">Заведомо ложные сообщения</h3>\n            </div>\n            <i class=\"ti ti-chevron-down text-xl text-gray-400 group-hover:text-[var(--safu-blue)] transition-all\" data-kid=\"160\"></i>\n          </div>\n          <div class=\"accordion-content bg-white px-8\" data-kid=\"161\">\n            <p class=\"py-6 text-gray-600 leading-relaxed\" data-kid=\"162\">\n              Помните: ложное сообщение об акте терроризма влечет уголовную ответственность по ст. 207 УК РФ. Это серьезное преступление, отвлекающее силы экстренных служб.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"fixed bottom-10 right-10 z-[60] flex flex-col gap-4\" data-kid=\"163\">\n    <a href=\"tel:+78182218505\" class=\"group flex items-center gap-4 bg-white p-2 rounded-full shadow-2xl border border-gray-100\" data-kid=\"164\">\n      <div class=\"w-12 h-12 bg-blue-500 text-white rounded-full flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"165\">\n        <i class=\"ti ti-brain text-2xl\" data-kid=\"166\"></i>\n      </div>\n      <span class=\"font-bold text-sm pr-6 text-gray-700 hidden group-hover:block transition-all\" data-kid=\"167\">Психологическая помощь</span>\n    </a>\n    <a href=\"tel:112\" class=\"group flex items-center gap-4 bg-[var(--safu-red)] p-2 rounded-full shadow-2xl border-4 border-white\" data-kid=\"168\">\n      <div class=\"w-12 h-12 bg-white text-[var(--safu-red)] rounded-full flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"169\">\n        <i class=\"ti ti-phone-call text-2xl\" data-kid=\"170\"></i>\n      </div>\n      <span class=\"font-bold text-lg pr-6 text-white uppercase tracking-wider\" data-kid=\"171\">112</span>\n    </a>\n  </div>\n\n  \n  <footer class=\"bg-slate-900 text-white pt-24 pb-12 px-6\" data-kid=\"172\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"173\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16 mb-20\" data-kid=\"174\">\n        <div class=\"col-span-1 md:col-span-2 space-y-8\" data-kid=\"175\">\n          <img src=\"/logo.png\" alt=\"САФУ\" class=\"h-16 w-auto brightness-0 invert\" decoding=\"async\" loading=\"lazy\" data-kid=\"176\">\n          <p class=\"text-gray-400 text-lg max-w-md\" data-kid=\"177\">\n            Мы работаем над тем, чтобы каждый студент и сотрудник университета чувствовал себя под надежной защитой.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"178\">\n            <a href=\"#\" class=\"w-12 h-12 bg-white/10 rounded-full flex items-center justify-center hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"179\">\n              <i class=\"ti ti-brand-vk text-xl\" data-kid=\"180\"></i>\n            </a>\n            <a href=\"#\" class=\"w-12 h-12 bg-white/10 rounded-full flex items-center justify-center hover:bg-[var(--safu-blue)] transition-colors\" data-kid=\"181\">\n              <i class=\"ti ti-world text-xl\" data-kid=\"182\"></i>\n            </a>\n          </div>\n        </div>\n        \n        <div data-kid=\"183\">\n          <h4 class=\"font-heading font-bold mb-6 text-blue-400\" data-kid=\"184\">Контакты</h4>\n          <ul class=\"space-y-4 text-gray-400 text-sm\" data-kid=\"185\">\n            <li class=\"flex items-start gap-3\" data-kid=\"186\">\n              <i class=\"ti ti-map-pin text-[var(--safu-blue)]\" data-kid=\"187\"></i>\n              г. Архангельск, ул. Урицкого, 56\n            </li>\n            <li class=\"flex items-start gap-3\" data-kid=\"188\">\n              <i class=\"ti ti-phone text-[var(--safu-blue)]\" data-kid=\"189\"></i>\n              +7 (8182) 21-85-00\n            </li>\n            <li class=\"flex items-start gap-3\" data-kid=\"190\">\n              <i class=\"ti ti-mail text-[var(--safu-blue)]\" data-kid=\"191\"></i>\n              safety@narfu.ru\n            </li>\n          </ul>\n        </div>\n\n        <div data-kid=\"192\">\n          <h4 class=\"font-heading font-bold mb-6 text-blue-400\" data-kid=\"193\">Центр</h4>\n          <ul class=\"space-y-4 text-gray-400 text-sm\" data-kid=\"194\">\n            <li class=\"flex items-start gap-3\" data-kid=\"195\">\n              <i class=\"ti ti-map-pin text-[var(--safu-blue)]\" data-kid=\"196\"></i>\n              Ломоносова, 58, каб. 102\n            </li>\n            <li class=\"flex items-start gap-3\" data-kid=\"197\">\n              <i class=\"ti ti-phone text-[var(--safu-blue)]\" data-kid=\"198\"></i>\n              +7 (8182) 65-05-22\n            </li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"pt-12 border-t border-white/10 text-center text-gray-500 text-sm\" data-kid=\"199\">\n        © 2024 Координационный центр САФУ. Защищенное соединение.\n      </div>\n    </div>\n  </footer>\n</div>",
