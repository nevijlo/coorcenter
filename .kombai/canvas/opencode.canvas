      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Slab:wght@700;800&family=Roboto+Mono:wght@500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #1a202c;\n    background-color: #f5f5f5;\n  }\n\n  .font-heading {\n    font-family: 'Roboto Slab', serif;\n  }\n\n  .font-mono-ui {\n    font-family: 'Roboto Mono', monospace;\n  }\n\n  /* Custom Barcode Decoration */\n  .barcode-decor {\n    background-image: repeating-linear-gradient(90deg, #0066b3, #0066b3 2px, transparent 2px, transparent 4px);\n    height: 6px;\n    width: 100%;\n  }\n\n  .ticker-wrap {\n    overflow: hidden;\n    white-space: nowrap;\n  }\n\n  .ticker-content {\n    display: inline-block;\n    padding-left: 100%;\n    animation: ticker 30s linear infinite;\n  }\n\n  @keyframes ticker {\n    0% { transform: translate3d(0, 0, 0); }\n    100% { transform: translate3d(-100%, 0, 0); }\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <section class=\"flex flex-col lg:flex-row min-h-[600px]\" data-kid=\"2\">\n    \n    <div class=\"lg:w-7/12 bg-[#0066B3] text-white p-8 lg:p-20 flex flex-col justify-center relative overflow-hidden\" data-kid=\"3\">\n      \n      <div class=\"absolute inset-0 opacity-10 pointer-events-none\" style=\"background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;\" data-kid=\"4\"></div>\n      \n      <div class=\"relative z-10\" data-kid=\"5\">\n        <div class=\"mb-12 flex items-center gap-4\" data-kid=\"6\">\n          <img src=\"/api/local/images/center-logo.png\" alt=\"Логотип центра\" class=\"w-16 h-16 bg-white/10 rounded-lg p-2\" data-kid=\"7\">\n          <div class=\"font-mono-ui text-xs tracking-widest uppercase opacity-70\" data-kid=\"8\">Coordination Center <br data-kid=\"9\"> Security Protocol v4.1</div>\n        </div>\n        \n        <h1 class=\"font-heading text-4xl lg:text-6xl leading-[1.1] mb-8\" data-kid=\"10\">\n          Противодействие <br data-kid=\"11\"> идеологии экстремизма <br data-kid=\"12\"> и терроризма\n        </h1>\n        \n        <p class=\"text-xl text-blue-100 max-w-xl mb-12 font-medium\" data-kid=\"13\">\n          Официальная платформа координационного центра САФУ для обеспечения безопасности и профилактики угроз в образовательной среде.\n        </p>\n        \n        <div class=\"flex flex-wrap gap-4\" data-kid=\"14\">\n          <button class=\"bg-white text-[#0066B3] font-bold px-8 py-4 rounded-none border-2 border-white hover:bg-transparent hover:text-white transition-colors uppercase tracking-wider flex items-center gap-3\" data-kid=\"15\">\n            <i class=\"ti ti-file-warning text-xl\" data-kid=\"16\"></i> Сообщить о проблеме\n          </button>\n          <button class=\"border-2 border-white text-white font-bold px-8 py-4 rounded-none hover:bg-white/10 transition-colors uppercase tracking-wider\" data-kid=\"17\">\n            Контакты центра\n          </button>\n        </div>\n      </div>\n    </div>\n    \n    \n    <div class=\"lg:w-5/12 bg-white flex items-center justify-center p-8 lg:p-12\" data-kid=\"18\">\n      <div class=\"max-w-md w-full border border-gray-200 shadow-2xl p-10 relative\" data-kid=\"19\">\n        <div class=\"absolute top-0 left-0 w-full h-1.5 bg-[#D62828]\" data-kid=\"20\"></div>\n        \n        <div class=\"text-[#D62828] mb-8\" data-kid=\"21\">\n          <i class=\"ti ti-alert-triangle-filled text-6xl\" data-kid=\"22\"></i>\n        </div>\n        \n        <h2 class=\"font-heading text-2xl text-gray-900 mb-6 uppercase tracking-tight\" data-kid=\"23\">ЭКСТРЕННОЕ УВЕДОМЛЕНИЕ</h2>\n        \n        <div class=\"space-y-6 text-gray-600 leading-relaxed border-l-4 border-gray-100 pl-6\" data-kid=\"24\">\n          <p data-kid=\"25\">\n            Если вам известно о готовящемся, совершенном или совершаемом в данный момент преступлении, в том числе террористической направленности:\n          </p>\n          \n          <div class=\"bg-gray-50 p-6 border border-gray-200\" data-kid=\"26\">\n            <div class=\"text-sm font-bold text-gray-400 uppercase tracking-widest mb-1\" data-kid=\"27\">Единая служба спасения</div>\n            <div class=\"text-5xl font-heading text-[#D62828] font-black\" data-kid=\"28\">112</div>\n          </div>\n          \n          <p class=\"text-sm italic\" data-kid=\"29\">\n            Немедленно свяжитесь с экстренными службами. Время реагирования имеет критическое значение.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[#D62828] text-white py-6 border-y border-white/20\" data-kid=\"30\">\n    <div class=\"flex items-center overflow-hidden whitespace-nowrap\" data-kid=\"31\">\n      <div class=\"px-8 font-mono-ui font-bold border-r border-white/30 shrink-0 uppercase tracking-widest\" data-kid=\"32\">\n        Emergency Lines:\n      </div>\n      <div class=\"flex items-center gap-16 animate-marquee\" data-kid=\"33\">\n        <div class=\"flex items-center gap-4\" data-kid=\"34\">\n          <span class=\"opacity-70 text-sm uppercase font-mono-ui\" data-kid=\"35\">ФСБ (Архангельск):</span>\n          <span class=\"text-2xl font-mono-ui font-bold\" data-kid=\"36\">+7 (8182) 21-83-87</span>\n        </div>\n        <div class=\"h-8 w-px bg-white/30\" data-kid=\"37\"></div>\n        <div class=\"flex items-center gap-4\" data-kid=\"38\">\n          <span class=\"opacity-70 text-sm uppercase font-mono-ui\" data-kid=\"39\">ФСБ (Дежурный):</span>\n          <span class=\"text-2xl font-mono-ui font-bold\" data-kid=\"40\">+7 (8182) 28-64-09</span>\n        </div>\n        <div class=\"h-8 w-px bg-white/30\" data-kid=\"41\"></div>\n        <div class=\"flex items-center gap-4\" data-kid=\"42\">\n          <span class=\"opacity-70 text-sm uppercase font-mono-ui\" data-kid=\"43\">Психологическая помощь:</span>\n          <span class=\"text-2xl font-mono-ui font-bold\" data-kid=\"44\">+7 (8182) 21-85-05</span>\n        </div>\n        \n        <div class=\"h-8 w-px bg-white/30\" data-kid=\"45\"></div>\n        <div class=\"flex items-center gap-4\" data-kid=\"46\">\n          <span class=\"opacity-70 text-sm uppercase font-mono-ui\" data-kid=\"47\">ФСБ (Архангельск):</span>\n          <span class=\"text-2xl font-mono-ui font-bold\" data-kid=\"48\">+7 (8182) 21-83-87</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-[#F5F5F5]\" data-kid=\"49\">\n    <div class=\"max-w-6xl mx-auto px-8\" data-kid=\"50\">\n      <div class=\"flex items-end justify-between mb-16 border-b border-gray-300 pb-8\" data-kid=\"51\">\n        <div data-kid=\"52\">\n          <h2 class=\"font-heading text-4xl mb-4\" data-kid=\"53\">Классификатор угроз</h2>\n          <p class=\"text-gray-500 max-w-md uppercase text-xs tracking-[0.2em] font-bold\" data-kid=\"54\">Выберите соответствующий протокол обращения</p>\n        </div>\n        <div class=\"font-mono-ui text-4xl text-gray-200 font-bold\" data-kid=\"55\">09 UNITS</div>\n      </div>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border border-gray-300\" data-kid=\"56\">\n        \n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"57\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"58\">\n            <i class=\"ti ti-shield-alert text-4xl\" data-kid=\"59\"></i>\n          </div>\n          <div data-kid=\"60\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"61\">Protocol A-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"62\">Буллинг и травля</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"63\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"64\">\n            <i class=\"ti ti-device-laptop text-4xl\" data-kid=\"65\"></i>\n          </div>\n          <div data-kid=\"66\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"67\">Protocol A-02</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"68\">Кибербуллинг</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"69\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"70\">\n            <i class=\"ti ti-eye text-4xl\" data-kid=\"71\"></i>\n          </div>\n          <div data-kid=\"72\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"73\">Protocol B-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"74\">Подозрительные публикации</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"75\">\n          <div class=\"text-[#D62828]\" data-kid=\"76\">\n            <i class=\"ti ti-alert-octagon text-4xl\" data-kid=\"77\"></i>\n          </div>\n          <div data-kid=\"78\">\n            <div class=\"font-mono-ui text-xs text-[#D62828] mb-2 uppercase opacity-60\" data-kid=\"79\">Protocol X-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"80\">Терроризм и экстремизм</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"81\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"82\">\n            <i class=\"ti ti-users-group text-4xl\" data-kid=\"83\"></i>\n          </div>\n          <div data-kid=\"84\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"85\">Protocol C-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"86\">Межнациональные конфликты</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"87\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"88\">\n            <i class=\"ti ti-flame text-4xl\" data-kid=\"89\"></i>\n          </div>\n          <div data-kid=\"90\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"91\">Protocol D-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"92\">Деструктивное поведение</h3>\n          </div>\n        </div>\n\n        <div class=\"bg-white p-12 border border-gray-300 hover:border-[#0066B3] hover:bg-blue-50/30 transition-all cursor-pointer group flex flex-col justify-between min-h-[300px]\" data-kid=\"93\">\n          <div class=\"text-gray-400 group-hover:text-[#0066B3] transition-colors\" data-kid=\"94\">\n            <i class=\"ti ti-school text-4xl\" data-kid=\"95\"></i>\n          </div>\n          <div data-kid=\"96\">\n            <div class=\"font-mono-ui text-xs text-gray-400 mb-2 uppercase\" data-kid=\"97\">Protocol E-01</div>\n            <h3 class=\"font-bold text-xl leading-snug\" data-kid=\"98\">Угрозы в вузе</h3>\n   