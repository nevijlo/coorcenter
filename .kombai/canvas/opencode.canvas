kid=\"117\">\n          \n          <div class=\"space-y-6\" data-kid=\"118\">\n            <div class=\"flex items-center gap-4 text-gray-400 font-mono-ui text-xs uppercase tracking-[0.3em]\" data-kid=\"119\">\n              <span class=\"bg-gray-100 px-3 py-1 text-gray-600\" data-kid=\"120\">Step 01</span>\n              <div class=\"h-px grow bg-gray-200\" data-kid=\"121\"></div>\n              <span data-kid=\"122\">Category Selection</span>\n            </div>\n            <div class=\"relative\" data-kid=\"123\">\n              <select class=\"w-full h-16 px-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none appearance-none font-bold text-lg\" data-kid=\"124\">\n                <option value disabled selected data-kid=\"125\">Выберите категорию обращения...</option>\n                <option data-kid=\"126\">Буллинг / травля</option>\n                <option data-kid=\"127\">Кибербуллинг</option>\n                <option data-kid=\"128\">Подозрительные публикации</option>\n                <option data-kid=\"129\">Терроризм и экстремизм</option>\n              </select>\n              <div class=\"absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\" data-kid=\"130\">\n                <i class=\"ti ti-chevron-down text-xl\" data-kid=\"131\"></i>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-6\" data-kid=\"132\">\n            <div class=\"flex items-center gap-4 text-gray-400 font-mono-ui text-xs uppercase tracking-[0.3em]\" data-kid=\"133\">\n              <span class=\"bg-gray-100 px-3 py-1 text-gray-600\" data-kid=\"134\">Step 02</span>\n              <div class=\"h-px grow bg-gray-200\" data-kid=\"135\"></div>\n              <span data-kid=\"136\">Statement Details</span>\n            </div>\n            <textarea rows=\"6\" placeholder=\"Опишите ситуацию максимально подробно (кто, где, когда, при каких обстоятельствах)...\" class=\"w-full p-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none font-medium resize-none leading-relaxed\" data-kid=\"137\"></textarea>\n          </div>\n\n          \n          <div class=\"space-y-6\" data-kid=\"138\">\n            <div class=\"flex items-center gap-4 text-gray-400 font-mono-ui text-xs uppercase tracking-[0.3em]\" data-kid=\"139\">\n              <span class=\"bg-gray-100 px-3 py-1 text-gray-600\" data-kid=\"140\">Step 03</span>\n              <div class=\"h-px grow bg-gray-200\" data-kid=\"141\"></div>\n              <span data-kid=\"142\">Contextual Data</span>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"143\">\n              <input type=\"text\" placeholder=\"Учебное заведение / Высшая школа\" class=\"w-full h-14 px-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none font-medium\" data-kid=\"144\">\n              <input type=\"text\" placeholder=\"Место происшествия (адрес, ауд.)\" class=\"w-full h-14 px-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none font-medium\" data-kid=\"145\">\n              <input type=\"text\" placeholder=\"Направление / Курс\" class=\"w-full h-14 px-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none font-medium\" data-kid=\"146\">\n              <input type=\"text\" placeholder=\"Контактные данные (по желанию)\" class=\"w-full h-14 px-6 bg-gray-50 border-2 border-gray-200 focus:border-[#0066B3] focus:bg-white outline-none font-medium\" data-kid=\"147\">\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-6\" data-kid=\"148\">\n            <div class=\"flex items-center gap-4 text-gray-400 font-mono-ui text-xs uppercase tracking-[0.3em]\" data-kid=\"149\">\n              <span class=\"bg-gray-100 px-3 py-1 text-gray-600\" data-kid=\"150\">Step 04</span>\n              <div class=\"h-px grow bg-gray-200\" data-kid=\"151\"></div>\n              <span data-kid=\"152\">Material Evidence</span>\n            </div>\n            <label class=\"flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-gray-300 bg-gray-50 hover:bg-gray-100 transition-colors cursor-pointer group\" data-kid=\"153\">\n              <div class=\"flex flex-col items-center justify-center pt-5 pb-6\" data-kid=\"154\">\n                <i class=\"ti ti-upload text-3xl text-gray-400 group-hover:text-[#0066B3] mb-2\" data-kid=\"155\"></i>\n                <p class=\"mb-1 text-sm text-gray-500 font-bold uppercase tracking-wider\" data-kid=\"156\">Прикрепить файлы</p>\n                <p class=\"text-xs text-gray-400\" data-kid=\"157\">PDF, JPG, PNG, DOC (Max. 20MB)</p>\n              </div>\n              <input type=\"file\" class=\"hidden\" data-kid=\"158\">\n            </label>\n          </div>\n\n          <button type=\"submit\" class=\"w-full bg-[#0066B3] text-white h-20 font-heading text-xl uppercase tracking-[0.2em] border-2 border-[#0066B3] hover:bg-[#D62828] hover:border-[#D62828] transition-all flex items-center justify-center gap-4 group\" data-kid=\"159\">\n            <i class=\"ti ti-send-2 text-2xl group-hover:translate-x-2 transition-transform\" data-kid=\"160\"></i> Направить на рассмотрение\n          </button>\n        </form>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-[#F5F5F5]\" data-kid=\"161\">\n    <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"162\">\n      <h2 class=\"font-heading text-4xl text-center mb-16 uppercase tracking-tight\" data-kid=\"163\">Командный состав центра</h2>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6\" data-kid=\"164\">\n        \n        <div class=\"bg-white border border-gray-200 relative group overflow-hidden\" data-kid=\"165\">\n          <div class=\"barcode-decor\" data-kid=\"166\"></div>\n          <div class=\"p-8\" data-k