    "var_170fba84533e": {
      "type": "variant",
      "label": "Analytical & Razor-Sharp",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 5890,
        "y": 0,
        "w": 1280,
        "h": 800
